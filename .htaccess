# ----------------------------------------------------------------------
# PORTFELIO APACHE CONFIGURATION & SECURITY SHIELD
# ----------------------------------------------------------------------

# Disable Directory Browsing
Options -Indexes

# Clean URLs: Force removal of .html and .php extensions
<IfModule mod_rewrite.c>
    RewriteEngine On

    # 1. Redirect direct requests for .php files to clean URL
    RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s([^.]+)\.php [NC]
    RewriteRule ^ %1 [R=301,L]

    # 2. Redirect direct requests for .html files to clean URL
    # Redirect index.html to the directory root
    RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s(.*)/index\.html [NC]
    RewriteRule ^ %1/ [R=301,L]
    
    RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s([^.]+)\.html [NC]
    RewriteRule ^ %1 [R=301,L]

    # 3. Internally rewrite extensionless requests back to their files
    # Don't do anything if a directory is requested
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Rewrite to .php if the file exists
    RewriteCond %{REQUEST_FILENAME}.php -f
    RewriteRule ^(.*)$ $1.php [L]

    # Rewrite to .html if the file exists
    RewriteCond %{REQUEST_FILENAME}.html -f
    RewriteRule ^(.*)$ $1.html [L]
</IfModule>

# Security Headers
<IfModule mod_headers.c>
    # Stand against Content-Type sniffing (nosniff)
    Header set X-Content-Type-Options "nosniff"
    
    # Stand against Clickjacking (SAMEORIGIN)
    Header set X-Frame-Options "SAMEORIGIN"
    
    # Enable XSS filtering in browsers
    Header set X-XSS-Protection "1; mode=block"
    
    # Referrer policy for privacy
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    
    # Secure Content Security Policy (allows Google Fonts and FontAwesome CDN)
    Header set Content-Security-Policy "default-src 'self' https:; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdnjs.cloudflare.com; style-src 'self' 'unsafe-inline' https://cdnjs.cloudflare.com https://fonts.googleapis.com; font-src 'self' https://cdnjs.cloudflare.com https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self';"
</IfModule>

# Hide sensitive folders (Git, system logs)
RedirectMatch 404 /\.(git|github|env|idea|system_generated)/

# Compress contents via GZIP to make site loading fast
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json
</IfModule>

# Cache static assets for speed optimization
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType text/javascript "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
</IfModule>
